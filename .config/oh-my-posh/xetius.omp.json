{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "background": "#292e42",
          "foreground": "#9ea5c9",
          "powerline_symbol": "\ue0b0",
          "options": {
            "style": "folder"
          },
          "style": "powerline",
          "template": " {{ .Path }} ",
          "type": "path"
        },
        {
          "background": "#3b4261",
          "foreground": "#a6add2",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#db4b4b{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#e0af68{{ end }}",
            "{{ if gt .Ahead 0 }}#9ece6a{{ end }}",
            "{{ if gt .Behind 0 }}#9ece6a{{ end }}"
          ],
          "foreground_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#292e42{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#292e42{{ end }}",
            "{{ if gt .Ahead 0 }}#292e42{{ end }}",
            "{{ if gt .Behind 0 }}#292e42{{ end }}"
          ],
          "leading_diamond": "\ue0b6",
          "powerline_symbol": "\ue0b0",
          "options": {
            "branch_template": "{{ trunc 25 .Branch }}",
            "fetch_status": true,
            "branch_icon": "\uE0A0 ",
            "branch_identical_icon": "\u25CF"
          },
          "style": "powerline",
          "template": " {{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }} \uf046 {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }} \ueb4b {{ .StashCount }}{{ end }} ",
          "trailing_diamond": "\ue0b4",
          "type": "git"
        },
        {
          "type": "kubectl",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "#000000",
          "background": "#7aa2f7",
          "template": " ﴱ {{.Context}}{{if .Namespace}} :: {{.Namespace}}{{end}} ",
          "options": {
            "context_aliases": {
              "arn:aws:eks:eu-west-1:679075971591:cluster/core-services-dev": "core-services-dev",
              "arn:aws:eks:eu-west-1:679075971591:cluster/core-services-temp-chudson": "core-services-temp-chudson"
            },
            "cluster_aliases": {
              "kind-kind": "Kind"
            }
          }
        },
        {
          "background_templates": [
            "{{if contains \"default\" .Profile}}#e0af68{{end}}",
            "{{if contains \"jan\" .Profile}}#db4b4b{{end}}"
          ],
          "foreground": "#ffffff",
          "powerline_symbol": "\ue0b0",
          "options": {
            "display_default": false
          },
          "style": "powerline",
          "template": " \ue7ad {{ .Profile }}{{ if .Region }}@{{ .Region }}{{ end }} ",
          "type": "aws"
        },
        {
          "background": "#1b1e2d",
          "foreground": "#7aa2f7",
          "powerline_symbol": "\ue0b0",
          "style": "powerline",
          "template": " \uf0ad ",
          "type": "root"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "#89ddff",
          "foreground_templates": ["{{ if gt .Code 0 }}#1f2335{{ end }}"],
          "options": {
            "always_enabled": true
          },
          "style": "plain",
          "template": "\u276f ",
          "type": "status"
        }
      ],
      "type": "prompt"
    }
  ],
  "console_title_template": "{{ .Folder }}",
  "final_space": true,
  "version": 4
}
